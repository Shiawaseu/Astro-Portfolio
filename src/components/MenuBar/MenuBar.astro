---
import {
  Home,
  BookText,
  Github,
  Mail,
  MoonStar,
  Wrench,
  Sun,
  Coffee
} from "lucide-astro";
import { Separator } from "@/components/ui/separator";
import "./Balloon.css";
---

<div
  id="menu-bar"
  class="fixed left-0 right-0 bottom-[-90px] flex justify-center transition-all duration-500 ease-out"
  transition:persist
  transition:persist-props
>
  <div
    class="resizeable-container relative flex items-center h-14 px-5 space-x-3 border shadow-xl backdrop-blur-md rounded-full bg-background/80 animate-[floatbar_5s_ease-in-out_infinite]"
  >
    <a
      aria-label="Home"
      data-balloon-pos="up"
      class="icon-wrapper flex items-center justify-center w-9 h-9"
      href="/"
    >
      <Home class="icon w-5 h-5" />
    </a>

    <a
      aria-label="Projects"
      data-balloon-pos="up"
      class="icon-wrapper flex items-center justify-center w-9 h-9"
      href="/projects"
    >
      <Wrench class="icon w-5 h-5" />
    </a>

    <a
      aria-label="Blog"
      data-balloon-pos="up"
      class="icon-wrapper flex items-center justify-center w-9 h-9"
      href="/blog"
    >
      <BookText class="icon w-5 h-5" />
    </a>

    <Separator
      orientation="vertical"
      className="h-6 mx-2 bg-black/40 dark:bg-white/20"
    />

    <a
      aria-label="Github"
      data-balloon-pos="up"
      class="icon-wrapper flex items-center justify-center w-9 h-9"
      href="https://github.com/shiawaseu"
    >
      <Github class="icon w-5 h-5" />
    </a>

    <a
      aria-label="Buy me a coffee"
      data-balloon-pos="up"
      class="icon-wrapper flex items-center justify-center w-9 h-9"
      href="https://buymeacoffee.com/shiawase"
    >
      <Coffee class="icon w-5 h-5" />
    </a>

    <a
      aria-label="Email"
      data-balloon-pos="up"
      class="icon-wrapper flex items-center justify-center w-9 h-9"
      href="mailto:shiawaseu@proton.me"
    >
      <Mail class="icon w-5 h-5" />
    </a>

    <Separator
      orientation="vertical"
      className="h-6 mx-2 bg-black/40 dark:bg-white/20"
    />

    <button
      aria-label="Theme"
      data-balloon-pos="up"
      id="theme-selector"
      class="icon-wrapper flex items-center justify-center w-9 h-9"
    >
      <Sun class="icon w-5 h-5 hidden dark:block" />
      <MoonStar class="icon w-5 h-5 dark:hidden" />
    </button>
  </div>
</div>

<script>
  const menuBar = document.getElementById("menu-bar") as HTMLElement | null;

  if (menuBar) {
    document.addEventListener("mousemove", (e: MouseEvent) => {
      const triggerZone = window.innerHeight - 120;

      if (e.clientY > triggerZone) {
        menuBar.style.bottom = "12px";
      } else {
        menuBar.style.bottom = "-90px";
      }
    });
  }

  /* Themes */

  const themeSelector = document.querySelector(
    "#theme-selector"
  ) as HTMLElement | null;

  function setTheme(theme: string) {
    const html = document.documentElement;

    if (theme === "dark") {
      html.classList.add("dark");
      localStorage.setItem("theme", "dark");
    } else {
      html.classList.remove("dark");
      localStorage.setItem("theme", "light");
    }
  }

  function loadThemePreference() {
    const savedTheme = localStorage.getItem("theme");

    if (savedTheme) {
      setTheme(savedTheme);
    } else {
      const prefersDark = window.matchMedia(
        "(prefers-color-scheme: dark)"
      ).matches;

      setTheme(prefersDark ? "dark" : "light");
    }
  }

  themeSelector?.addEventListener("click", () => {
    const current = document.documentElement.classList.contains("dark")
      ? "light"
      : "dark";

    setTheme(current);
  });

  loadThemePreference();

  document.addEventListener("astro:after-swap", () => {
    loadThemePreference();
  });
</script>